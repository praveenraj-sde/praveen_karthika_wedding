}
.ev-venue-link:hover .ev-vname { text-decoration: underline; text-underline-offset: 2px; }
.ev-venue-pin { font-size: 1.1rem; padding-top: 0.1rem; flex-shrink: 0; }
/* "tap to open" hint on the venue link */
.ev-venue-link::after {
