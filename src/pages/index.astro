/* ─── RSVP ────────────────────────────────────────────── */
.rsvp-sec {
  position: relative;
  background: var(--dark-3);
  padding: 6.5rem 1.5rem;
  text-align: center;
  overflow: hidden;
}
.rsvp-sec::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(to right, transparent, var(--gold), transparent);
}
.rsvp-sec::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(to right, transparent, var(--gold), transparent);
}
.rsvp-bg-accent {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-family: var(--fs);
  font-size: clamp(8rem, 20vw, 18rem);
  color: rgba(201,162,85,0.04);
  white-space: nowrap; pointer-events: none; user-select: none; line-height: 1;
}
.rsvp-bg-accent::before { content: 'Join Us'; }
.rsvp-wrap { max-width: 660px; position: relative; z-index: 1; }
.rsvp-heading {
  font-family: var(--fs);
  font-size: clamp(2.8rem, 8vw, 4.5rem);
  color: var(--gold);
  -webkit-text-stroke: 0.5px rgba(201,162,85,0.35);
  line-height: 1; margin-bottom: 0.5rem;
}
.rsvp-sub {
  font-family: var(--fh); font-style: italic;
  font-size: 0.95rem; color: var(--text-muted);
  margin-bottom: 2.75rem;
}
.rsvp-sub strong { color: var(--text-light); font-style: normal; }
.rsvp-card {
  background: var(--cream);
  padding: 2.75rem;
  text-align: left;
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}
@media (max-width: 520px) { .rsvp-card { padding: 1.5rem; } }

/* Form layout */
.rsvp-form { display: flex; flex-direction: column; gap: 1rem; }

/* Section blocks — white cards on cream background */
.form-section {
  background: #fff;
  padding: 1.75rem 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.6rem;
  border-left: 3px solid rgba(201,162,85,0.3);
}
@media (max-width: 520px) { .form-section { padding: 1.4rem 1.25rem; } }

.form-section-label {
  font-family: var(--fh);
  font-style: italic;
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 0.1rem;
}

.field { display: flex; flex-direction: column; gap: 0.6rem; }
.flabel {
  font-family: var(--fb); font-size: 0.76rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink);
}
.field-date {
  font-weight: 400; letter-spacing: 0; text-transform: none;
  opacity: 0.55; font-size: 0.88em;
}
.optional { font-weight: 400; letter-spacing: 0; text-transform: none; opacity: 0.5; font-size: 0.88em; }

.finput {
  width: 100%; padding: 0.85rem 1.1rem;
  border: 1.5px solid rgba(74,37,53,0.2);
  background: #fff; font-family: var(--fb); font-size: 0.95rem; color: var(--ink);
  outline: none; -webkit-appearance: none; border-radius: 0;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.finput:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(201,162,85,0.12); }
.finput.error { border-color: #c0392b; }
.ftarea { resize: vertical; min-height: 85px; }

/* Select */
.select-wrap { position: relative; }
.select-wrap::after {
  content: '▾';
  position: absolute; right: 0.9rem; top: 50%;
  transform: translateY(-50%);
  pointer-events: none; color: rgba(74,37,53,0.45); font-size: 0.85rem;
}
.fselect { cursor: pointer; padding-right: 2.2rem; }

/* Pills */
.pills { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 0.15rem; }
.pills input[type="radio"] { display: none; }
.pills label {
  padding: 0.6rem 1.35rem;
  border: 1.5px solid rgba(74,37,53,0.25); color: var(--ink);
  font-size: 0.82rem; font-weight: 600; cursor: pointer;
  border-radius: 100px;
  transition: background 0.18s, color 0.18s, border-color 0.18s;
  -webkit-tap-highlight-color: transparent; user-select: none;
}
.pills input[type="radio"]:checked + label { background: var(--ink); color: var(--cream); border-color: var(--ink); }

/* Field-level error */
.field-err {
  display: none;
  font-size: 0.72rem; color: #c0392b;
  font-family: var(--fb); margin-top: 0.15rem;
}

/* Form-level error banner */
.form-error-banner {
  background: #fdf0ef;
  border-left: 3px solid #c0392b;
  padding: 0.75rem 1rem;
  font-size: 0.82rem; color: #c0392b;
  font-family: var(--fb);
  margin-bottom: 0.5rem;
}

/* Submit button */
.rsvp-btn {
  width: 100%; padding: 0.95rem;
  background: var(--ink); color: var(--cream); border: none;
  font-family: var(--fb); font-weight: 700;
  font-size: 0.88rem; letter-spacing: 0.1em; text-transform: uppercase;
  cursor: pointer; border-radius: 0;
  transition: background 0.2s, transform 0.15s;
  display: flex; align-items: center; justify-content: center; gap: 0.5rem;
}
.rsvp-btn:hover:not(:disabled) { background: var(--gold); color: var(--dark); transform: translateY(-1px); }
.rsvp-btn:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }
.btn-spinner { display: flex; align-items: center; gap: 0.5rem; }
.spin-icon {
  width: 18px; height: 18px;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Success state */
.rsvp-success {
  padding: 3rem 2rem;
  text-align: center;
  display: flex; flex-direction: column; align-items: center; gap: 1.1rem;
}
.success-check { width: 76px; height: 76px; }
.check-svg { width: 100%; height: 100%; }
.check-circle {
  stroke: var(--gold); stroke-width: 2;
  stroke-dasharray: 160; stroke-dashoffset: 160;
  animation: draw-circle 0.65s ease forwards;
}
.check-tick {
  stroke: var(--gold); stroke-width: 3.5;
  stroke-linecap: round; stroke-linejoin: round;
  stroke-dasharray: 55; stroke-dashoffset: 55;
  animation: draw-tick 0.45s ease 0.55s forwards;
}
@keyframes draw-circle { to { stroke-dashoffset: 0; } }
@keyframes draw-tick   { to { stroke-dashoffset: 0; } }
.success-title { font-family: var(--fs); font-size: 2.5rem; color: var(--gold); line-height: 1; }
.success-sub {
  font-family: var(--fh); font-style: italic;
  color: var(--ink); font-size: 0.95rem;
  max-width: 300px; line-height: 1.65;
}
.success-again {
  margin-top: 0.25rem;
  background: none; border: 1px solid rgba(74,37,53,0.18);
  color: rgba(74,37,53,0.45); font-size: 0.7rem;
  letter-spacing: 0.08em; padding: 0.4rem 1rem;
  cursor: pointer; text-transform: uppercase; font-family: var(--fb);
  transition: border-color 0.2s, color 0.2s;
}
.success-again:hover { border-color: var(--ink); color: var(--ink); }

/* ─── PHOTO UPLOAD ────────────────────────────────────── */
.upload-sec {
