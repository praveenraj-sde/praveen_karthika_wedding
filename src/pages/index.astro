}

/* ─── GALLERY ─────────────────────────────────────────── */
.gallery-sec { background: var(--dark-2); padding: 5.5rem 1.5rem; }
.gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; margin: 0 auto 1.75rem; max-width: 900px; }
@media (max-width: 540px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
.gcard { display: flex; flex-direction: column; overflow: hidden; }
.gph { aspect-ratio: 4/5; background: var(--dark); border: 1px solid rgba(201,162,85,0.12); display: flex; align-items: center; justify-content: center; }
.gph-icon { width: 38px; opacity: 0.28; margin: 0 auto; }
.glabel { font-family: var(--fh); font-style: italic; font-size: 0.75rem; color: var(--text-muted); padding: 0.5rem 0; letter-spacing: 0.05em; text-align: center; }
.gallery-note { font-size: 0.8rem; color: var(--text-muted); font-style: italic; text-align: center; }

/* ─── FOOTER ──────────────────────────────────────────── */
.site-footer { background: var(--dark); border-top: 1px solid rgba(201,162,85,0.1); padding: 3.5rem 1.5rem; text-align: center; }
.footer-inner { max-width: 420px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
.footer-logo { width: 46px; opacity: 0.55; margin-bottom: 0.5rem; }
.footer-names { font-family: var(--fs); font-size: 1.7rem; color: var(--gold); line-height: 1; }
.footer-date { font-size: 0.75rem; color: var(--text-muted); letter-spacing: 0.07em; }
.footer-contacts { margin-top: 0.75rem; font-size: 0.8rem; color: var(--text-muted); display: flex; flex-direction: column; gap: 0.2rem; }
.footer-tel { display: block; color: var(--text-light); text-decoration: none; font-weight: 600; font-size: 0.88rem; }
.footer-map { margin-top: 0.5rem; font-size: 0.78rem; color: var(--gold); text-decoration: none; letter-spacing: 0.04em; }
.footer-copy { margin-top: 1.75rem; font-size: 0.65rem; color: rgba(240,223,200,0.2); letter-spacing: 0.07em; }

/* ─── FLOATING PILLS ─────────────────────────────────── */
.rsvp-fab {
  position: fixed; bottom: 1.5rem; right: 1.5rem;
  background: var(--gold); color: var(--dark);
  padding: 0.7rem 1.55rem;
  font-family: var(--fb); font-weight: 700;
  font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase;
  text-decoration: none; border-radius: 100px;
  box-shadow: 0 4px 20px rgba(201,162,85,0.38);
  opacity: 0; transform: translateY(14px);
  transition: opacity 0.3s, transform 0.3s, background 0.2s;
  z-index: 200; pointer-events: none;
}
.rsvp-fab.show { opacity: 1; transform: translateY(0); pointer-events: auto; }
.rsvp-fab:hover { background: #dbb96a; }

.share-fab {
  position: fixed; bottom: 4.5rem; right: 1.5rem;
  background: var(--dark-3);
  border: 1.5px solid var(--gold); color: var(--gold);
  padding: 0.65rem 1.3rem;
  font-family: var(--fb); font-weight: 700;
  font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
  text-decoration: none; border-radius: 100px;
  opacity: 0; transform: translateY(14px);
  transition: opacity 0.3s, transform 0.3s;
  z-index: 200; pointer-events: none;
}
.share-fab.show { opacity: 1; transform: translateY(0); pointer-events: auto; }
.share-fab:hover { background: var(--gold-dim); }
.share-fab.upload-btn-disabled { color: rgba(201,162,85,0.35) !important; border-color: rgba(201,162,85,0.2) !important; cursor: not-allowed; pointer-events: none; }
</style>

<!-- ════════════════════════════════════════════════════════
     CLIENT SCRIPTS
════════════════════════════════════════════════════════ -->
<script>

  // ── Countdown ───────────────────────────────────────────
  const target = new Date('2026-09-13T07:00:00+05:30');
  function tick() {
    const diff = target.getTime() - Date.now();
    if (diff <= 0) {
      const el = document.getElementById('countdown');
      if (el) el.innerHTML = '<p style="font-family:var(--fs);font-size:2rem;color:var(--gold)">It\'s the Big Day! 🎉</p>';
      return;
    }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const pad = (n) => String(n).padStart(2, '0');
    document.getElementById('cd-d').textContent = String(d);
    document.getElementById('cd-h').textContent = pad(h);
    document.getElementById('cd-m').textContent = pad(m);
    document.getElementById('cd-s').textContent = pad(s);
  }
  tick();
  setInterval(tick, 1000);

  // ── Scroll reveal ───────────────────────────────────────
  const io = new IntersectionObserver(
    entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // ── Floating pills ──────────────────────────────────────
  const fab      = document.getElementById('rsvp-fab');
  const shareFab = document.getElementById('share-fab');
  const hero     = document.getElementById('hero');
  function syncFabs() {
    const show = window.scrollY > hero.offsetHeight * 0.55;
    fab.classList.toggle('show', show);
    shareFab.classList.toggle('show', show);
  }
  window.addEventListener('scroll', syncFabs, { passive: true });
  syncFabs();

  // ── Share the Moment date gate ──────────────────────────
  const shareEnableDate = new Date('2026-09-05T00:00:00+05:30');
  const driveBtn   = document.getElementById('drive-link');
  const uploadNote = document.querySelector('.upload-note');
  if (driveBtn && Date.now() < shareEnableDate.getTime()) {
    driveBtn.classList.add('upload-btn-disabled');
    driveBtn.removeAttribute('href');
    // Share FAB stays clickable — it scrolls to the section so guests can read the countdown
    if (uploadNote) {
      const daysLeft = Math.ceil((shareEnableDate.getTime() - Date.now()) / 86400000);
      uploadNote.textContent = `Uploads open from 5th September 2026 — ${daysLeft} day${daysLeft !== 1 ? 's' : ''} away`;
    }
  }

  // ── Guests — show custom input ──────────────────────────
  const guestsSelect = document.getElementById('f-guests');
  const guestsCustom = document.getElementById('f-guests-custom');
  guestsSelect.addEventListener('change', () => {
    const show = guestsSelect.value === 'custom';
    guestsCustom.style.display = show ? 'block' : 'none';
    if (show) guestsCustom.focus();
  });

  // ── RSVP Form — Google Apps Script backend ──────────────
  const form       = document.getElementById('rsvp-form');
  const submitBtn  = document.getElementById('rsvp-submit');
  const btnLabel   = submitBtn.querySelector('.btn-label');
  const btnSpinner = submitBtn.querySelector('.btn-spinner');
  const formError  = document.getElementById('form-error');
  const formErrMsg = document.getElementById('form-error-msg');
  const successDiv = document.getElementById('rsvp-success');
  const againBtn   = document.getElementById('rsvp-again');

  function showFieldErr(id, msg) {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg;
    el.style.display = 'block';
    // Mark the associated input
    const field = el.closest('.field');
    if (field) {
      const input = field.querySelector('.finput');
      if (input) input.classList.add('error');
    }
  }

  function clearErrors() {
    document.querySelectorAll('.field-err').forEach(el => {
      el.textContent = '';
      el.style.display = 'none';
    });
    document.querySelectorAll('.finput').forEach(el => el.classList.remove('error'));
    formError.hidden = true;
  }

  function validate(d) {
    let ok = true;
    if (!d.name || d.name.length < 2) {
      showFieldErr('err-name', 'Please enter your full name');
      ok = false;
    }
    if (!d.phone || d.phone.replace(/\D/g, '').length < 7) {
      showFieldErr('err-phone', 'Please enter a valid phone number');
      ok = false;
    }
    if (!d.engagement) {
      showFieldErr('err-engagement', 'Please select your Engagement attendance');
      ok = false;
    }
    if (!d.wedding) {
      showFieldErr('err-wedding', 'Please select your Wedding attendance');
      ok = false;
    }
    if (!d.category) {
      showFieldErr('err-category', "Please let us know if you're from the bride's or groom's side");
      ok = false;
    }
    return ok;
  }

  function setLoading(on) {
    submitBtn.disabled = on;
    btnLabel.hidden    = on;
    btnSpinner.hidden  = !on;
  }

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    clearErrors();

    const fd = new FormData(form);

    // Resolve guest count
    let guests = fd.get('guests') || '';
    if (guests === 'custom') {
      guests = fd.get('guests_custom') || '';
    }

    const data = {
      name:         (fd.get('name')       || '').toString().trim(),
      phone:        (fd.get('phone')      || '').toString().trim(),
      engagement:   (fd.get('engagement') || '').toString().trim(),
      wedding:      (fd.get('wedding')    || '').toString().trim(),
      guests:       guests.toString().trim(),
      category:     (fd.get('category')   || '').toString().trim(),
      transport:    (fd.get('transport')  || '').toString().trim(),
      room:         (fd.get('room')       || '').toString().trim(),
      message:      (fd.get('message')    || '').toString().trim(),
      _honeypot:    (fd.get('_honeypot')  || '').toString(),
      userAgent:    navigator.userAgent,
    };

    if (!validate(data)) {
      // Scroll to first error
      const firstErr = form.querySelector('.field-err[style*="block"]');
      if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    setLoading(true);

    try {
      const res = await fetch('/.netlify/functions/rsvp', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      let result;
      try { result = await res.json(); }
      catch (_) { result = { success: false, error: 'Could not read server response' }; }

      if (result.success) {
        form.hidden    = true;
        successDiv.hidden = false;
        successDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } else {
        formErrMsg.textContent = result.error || 'Submission failed. Please try again.';
        formError.hidden = false;
        formError.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    } catch (_) {
      formErrMsg.textContent = 'Network error — please check your connection and try again.';
      formError.hidden = false;
    } finally {
      setLoading(false);
    }
  });

  // "Submit another response" resets the form
  againBtn.addEventListener('click', () => {
    form.reset();
    guestsCustom.style.display = 'none';
    clearErrors();
    form.hidden    = false;
    successDiv.hidden = true;
  });

</script>
