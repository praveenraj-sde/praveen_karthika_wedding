---
import WeddingLayout from '../layouts/WeddingLayout.astro';
import '../styles/global.css';

const MAPS = 'https://maps.app.goo.gl/4SZqfbVj2TdEzto46';

const gcal = (text: string, start: string, end: string, details: string) =>
  `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(text)}&dates=${start}%2F${end}&details=${encodeURIComponent(details)}&location=${encodeURIComponent('Sathyabama Kalyana Mandapam, SH-44, 26/99, Ettayapuram Road, Kovilpatti – 628501')}`;
---

<WeddingLayout>

  <!-- ── Floating pills (appear on scroll) ─────────────── -->
  <a href="#upload" class="share-fab" id="share-fab" aria-label="Share Photos">📸 Share Photos</a>
  <a href="#rsvp"   class="rsvp-fab"  id="rsvp-fab"  aria-label="Confirm Attendance">I'll Attend ✓</a>

  <!-- ══════════════════════════════════════════════════════
       1. HERO
  ══════════════════════════════════════════════════════ -->
  <section class="hero" id="hero">
    <div class="hero-text">
      <img src="/wedding/elements/pk-logo-brown.png" class="hero-logo reveal" alt="PK monogram" />

      <p class="hero-tagline reveal rv2">Together with their families</p>

      <div class="hero-names reveal rv3">
        <span class="hname">Praveen Raj</span>
        <span class="weds-row">
          <span class="weds-line"></span>
          <em>weds</em>
          <span class="weds-line"></span>
        </span>
        <span class="hname">Karthika</span>
      </div>

      <div class="hero-meta reveal rv4">
        <img src="/wedding/elements/divider2-brown.png" class="hero-divi" alt="" aria-hidden="true" />
        <p class="hero-date">13th September 2026</p>
        <p class="hero-venue">Sathyabama Kalyana Mandapam · Kovilpatti</p>
      </div>

      <div class="countdown reveal rv5" id="countdown" aria-live="polite">
        <div class="cu"><span class="cn" id="cd-d">--</span><span class="cl">Days</span></div>
        <span class="cs" aria-hidden="true">:</span>
        <div class="cu"><span class="cn" id="cd-h">--</span><span class="cl">Hrs</span></div>
        <span class="cs" aria-hidden="true">:</span>
        <div class="cu"><span class="cn" id="cd-m">--</span><span class="cl">Min</span></div>
        <span class="cs" aria-hidden="true">:</span>
        <div class="cu"><span class="cn" id="cd-s">--</span><span class="cl">Sec</span></div>
      </div>

      <div class="hero-cta reveal rv5">
        <a href="#rsvp"   class="btn-gold">Confirm Attendance</a>
        <a href="#events" class="btn-outline">View Events ↓</a>
      </div>

      <!-- Quick-access row — Share Photos + Directions only -->
      <div class="hero-quick reveal rv5">
        <a href="#upload"  class="hq-item"><span>📸</span><span>Share Photos</span></a>
        <a href={MAPS} target="_blank" rel="noopener noreferrer" class="hq-item"><span>📍</span><span>Get Directions</span></a>
      </div>
    </div>

    <div class="hero-art">
      <img src="/wedding/couple-photo-nobg.webp" alt="Praveen and Karthika" />
    </div>

    <a class="scroll-hint" href="#events" aria-label="Scroll to events">↓</a>
  </section>

  <!-- ══════════════════════════════════════════════════════
       2. EVENTS
  ══════════════════════════════════════════════════════ -->
  <section class="events-sec" id="events">
    <div class="sec-wrap">
      <p class="section-tag reveal">Save the Date</p>
      <h2 class="section-heading section-heading-dark reveal rv2">Celebrate With Us</h2>
      <div class="section-rule rule-ink reveal rv2"></div>

      <div class="ev-grid">
        <!-- Engagement -->
        <article class="ev-card reveal">
          <img src="/wedding/elements/rings-brown.png" class="ev-icon" alt="" />
          <h3 class="ev-title">Engagement</h3>
          <p class="ev-date">Saturday, 12th September 2026</p>
          <p class="ev-time">7:00 PM – 8:00 PM</p>

          <a href={MAPS} target="_blank" rel="noopener noreferrer" class="ev-venue ev-venue-link">
            <span class="ev-venue-pin">📍</span>
            <span>
              <span class="ev-vname">Sathyabama Kalyana Mandapam</span>
              <span class="ev-vaddr">SH-44, 26/99, Ettayapuram Road<br />Kovilpatti – 628501, Tamilnadu</span>
            </span>
          </a>

          <div class="ev-actions">
            <a href={gcal('Praveen & Karthika – Engagement','20260912T133000Z','20260912T143000Z','Engagement ceremony. Time: 7:00 PM – 8:00 PM IST')}
               target="_blank" rel="noopener noreferrer" class="ev-btn ev-btn-cal">
              📅 Google Calendar
            </a>
            <a href="/wedding/events.ics" download class="ev-btn ev-btn-cal">
              📱 Apple Calendar / Outlook
            </a>
          </div>
        </article>

        <!-- Wedding -->
        <article class="ev-card reveal rv2">
          <img src="/wedding/elements/wedding-couple-brown.png" class="ev-icon" alt="" />
          <h3 class="ev-title">Wedding</h3>
          <p class="ev-date">Sunday, 13th September 2026</p>
          <p class="ev-time">Muhurtham: 7:00 AM – 9:00 AM</p>

          <a href={MAPS} target="_blank" rel="noopener noreferrer" class="ev-venue ev-venue-link">
            <span class="ev-venue-pin">📍</span>
            <span>
              <span class="ev-vname">Sathyabama Kalyana Mandapam</span>
              <span class="ev-vaddr">SH-44, 26/99, Ettayapuram Road<br />Kovilpatti – 628501, Tamilnadu</span>
            </span>
          </a>

          <div class="ev-actions">
            <a href={gcal('Praveen & Karthika – Wedding','20260913T013000Z','20260913T033000Z','Wedding ceremony. Muhurtham: 7:00 AM – 9:00 AM IST')}
               target="_blank" rel="noopener noreferrer" class="ev-btn ev-btn-cal">
              📅 Google Calendar
            </a>
            <a href="/wedding/events.ics" download class="ev-btn ev-btn-cal">
              📱 Apple Calendar / Outlook
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       3. CONFIRM ATTENDANCE
  ══════════════════════════════════════════════════════ -->
  <section class="rsvp-sec" id="rsvp">
    <div class="rsvp-bg-accent" aria-hidden="true"></div>
    <div class="sec-wrap rsvp-wrap">
      <p class="section-tag section-tag-muted reveal">You're Invited</p>
      <h2 class="rsvp-heading reveal rv2">Will You Join Us?</h2>
      <p class="rsvp-sub reveal rv3">Please respond at the <strong>earliest possible</strong> — by <strong>30th August 2026</strong></p>

      <div class="rsvp-card reveal rv3" id="rsvp-card">

        <!-- ── Success state ────────────────────────────────── -->
        <div class="rsvp-success" id="rsvp-success" hidden>
          <div class="success-check">
            <svg viewBox="0 0 52 52" class="check-svg" aria-hidden="true">
              <circle class="check-circle" cx="26" cy="26" r="24" fill="none" />
              <path   class="check-tick"   fill="none" d="M14 27l8 8 16-17" />
            </svg>
          </div>
          <h3 class="success-title">You're Confirmed!</h3>
          <p class="success-sub">Thank you for your response. We can't wait to celebrate with you! 🎉</p>
          <button class="success-again" id="rsvp-again" type="button">Submit another response</button>
        </div>

        <!-- ── Form ─────────────────────────────────────────── -->
        <form id="rsvp-form" novalidate autocomplete="off">
          <input type="text" name="_honeypot" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div class="form-error-banner" id="form-error" hidden role="alert">
            <span id="form-error-msg">Something went wrong. Please try again.</span>
          </div>

          <!-- ─ Section 1: Contact details ───────────────────── -->
          <div class="form-section">
            <p class="form-section-label">Your Details</p>

            <div class="field">
              <label class="flabel" for="f-name">Full Name *</label>
              <input class="finput" type="text" id="f-name" name="name"
                     placeholder="Ramesh Kumar" required autocomplete="name" />
              <span class="field-err" id="err-name"></span>
            </div>

            <div class="field">
              <label class="flabel" for="f-phone">Phone Number *</label>
              <input class="finput" type="tel" id="f-phone" name="phone"
                     placeholder="+91 98765 43210" required autocomplete="tel" />
              <span class="field-err" id="err-phone"></span>
            </div>
          </div>

          <!-- ─ Section 2: Attendance ─────────────────────────── -->
          <div class="form-section">
            <p class="form-section-label">Your Attendance</p>

            <div class="field">
              <span class="flabel">Engagement <span class="field-date">(12th Sep · 7 PM)</span> *</span>
              <div class="pills">
                <input type="radio" id="eng-y" name="engagement" value="Yes" required />
                <label for="eng-y">Attending 🎉</label>
                <input type="radio" id="eng-n" name="engagement" value="No" />
                <label for="eng-n">Can't make it</label>
              </div>
              <span class="field-err" id="err-engagement"></span>
            </div>

            <div class="field">
              <span class="flabel">Wedding <span class="field-date">(13th Sep · 7 AM)</span> *</span>
              <div class="pills">
                <input type="radio" id="wed-y" name="wedding" value="Yes" />
                <label for="wed-y">Attending 🎉</label>
                <input type="radio" id="wed-n" name="wedding" value="No" />
                <label for="wed-n">Can't make it</label>
              </div>
              <span class="field-err" id="err-wedding"></span>
            </div>
          </div>

          <!-- ─ Section 3: Party details ──────────────────────── -->
          <div class="form-section">
            <p class="form-section-label">Your Party</p>

            <div class="field">
              <label class="flabel" for="f-guests">Number of Guests <span class="optional">(including yourself)</span></label>
              <div class="select-wrap">
                <select class="finput fselect" id="f-guests" name="guests">
                  <option value="">Select count…</option>
                  <option value="1">1</option>
                  <option value="2">2</option>
                  <option value="3">3</option>
                  <option value="4">4</option>
                  <option value="5">5</option>
                  <option value="6">6</option>
                  <option value="7">7</option>
                  <option value="8">8</option>
                  <option value="9">9</option>
                  <option value="10">10</option>
                  <option value="custom">More than 10 — enter below ↓</option>
                </select>
              </div>
              <input class="finput" type="number" id="f-guests-custom" name="guests_custom"
                     placeholder="Enter exact number (e.g. 14)" min="11" max="500"
                     style="display:none; margin-top:0.65rem" />
            </div>

            <div class="field">
              <span class="flabel">You are... *</span>
              <div class="pills">
                <input type="radio" id="cat-bride" name="category" value="Bride's Friend/Family" required />
                <label for="cat-bride">Bride's Friend / Family</label>
                <input type="radio" id="cat-groom" name="category" value="Groom's Friend/Family" />
                <label for="cat-groom">Groom's Friend / Family</label>
              </div>
              <span class="field-err" id="err-category"></span>
            </div>
          </div>

          <!-- ─ Section 4: Logistics ──────────────────────────── -->
          <div class="form-section">
            <p class="form-section-label">Arrangements</p>

            <div class="field">
              <span class="flabel">Transport to Venue Required?</span>
              <div class="pills">
                <input type="radio" id="trans-y" name="transport" value="Yes" />
                <label for="trans-y">Yes please</label>
                <input type="radio" id="trans-n" name="transport" value="No" checked />
                <label for="trans-n">No, I'll manage</label>
              </div>
            </div>

            <div class="field">
              <span class="flabel">Room Arrangements Needed?</span>
              <div class="pills">
                <input type="radio" id="r-y" name="room" value="Yes" />
                <label for="r-y">Yes</label>
                <input type="radio" id="r-n" name="room" value="No" checked />
                <label for="r-n">No</label>
              </div>
            </div>
          </div>

          <!-- ─ Section 5: Message ────────────────────────────── -->
          <div class="form-section">
            <div class="field">
              <label class="flabel" for="f-msg">Message for the Couple <span class="optional">(optional)</span></label>
              <textarea class="finput ftarea" id="f-msg" name="message" rows="4"
                        placeholder="Write a blessing or a warm message…"></textarea>
            </div>
          </div>

          <!-- Submit -->
          <button type="submit" class="rsvp-btn" id="rsvp-submit">
            <span class="btn-label">Confirm Attendance ✓</span>
            <span class="btn-spinner" hidden aria-hidden="true">
              <svg class="spin-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
              </svg>
              Submitting…
            </span>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       4. SHARE THE MOMENT
  ══════════════════════════════════════════════════════ -->
  <section class="upload-sec" id="upload">
    <div class="upload-inner">
      <div class="upload-icon-wrap reveal" aria-hidden="true">📸</div>
      <h2 class="section-heading section-heading-light reveal rv2">Share the Moment</h2>
      <p class="upload-sub reveal rv3">
        Captured something beautiful at the celebration?<br />
        Upload your photos &amp; videos — let's build our shared memory together.
      </p>
      <a href="#" id="drive-link" class="upload-btn reveal rv4"
         target="_blank" rel="noopener noreferrer">
        Upload Photos &amp; Videos ↗
      </a>
      <p class="upload-note reveal rv5">Link will go live on the day of the event</p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       5. GALLERY
  ══════════════════════════════════════════════════════ -->
  <section class="gallery-sec" id="gallery" hidden style="display:none">
    <div class="sec-wrap" style="text-align:center">
      <p class="section-tag section-tag-muted reveal">Memories</p>
      <h2 class="section-heading section-heading-light reveal rv2">Our Story</h2>
      <div class="section-rule rule-gold reveal rv2"></div>

      <div class="gallery-grid">
        <div class="gcard reveal">
          <div class="gph"><img src="/wedding/elements/divider-heart-brown.png" class="gph-icon" alt="" /></div>
          <span class="glabel">First Meeting</span>
        </div>
        <div class="gcard reveal rv2">
          <div class="gph"><img src="/wedding/elements/rings-brown.png" class="gph-icon" alt="" /></div>
          <span class="glabel">The Proposal</span>
        </div>
        <div class="gcard reveal rv3">
          <div class="gph"><img src="/wedding/elements/butterfly-brown.png" class="gph-icon" alt="" /></div>
          <span class="glabel">Engagement Day</span>
        </div>
        <div class="gcard reveal rv2">
          <div class="gph"><img src="/wedding/elements/wedding-couple-brown.png" class="gph-icon" alt="" /></div>
          <span class="glabel">Celebrations</span>
        </div>
        <div class="gcard reveal rv3">
          <div class="gph"><img src="/wedding/elements/divider-heart-brown.png" class="gph-icon" alt="" /></div>
          <span class="glabel">Together</span>
        </div>
        <div class="gcard reveal rv4">
          <div class="gph"><img src="/wedding/elements/pk-logo-brown.png" class="gph-icon" alt="" /></div>
          <span class="glabel">Forever Begins</span>
        </div>
      </div>

      <p class="gallery-note reveal">Photos coming soon — stay tuned! ✨</p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       FOOTER
  ══════════════════════════════════════════════════════ -->
  <footer class="site-footer">
    <div class="footer-inner">
      <img src="/wedding/elements/pk-logo-brown.png" class="footer-logo" alt="PK" />
      <p class="footer-names">Praveen Raj &amp; Karthika</p>
      <p class="footer-date">13th September 2026 · Kovilpatti</p>
      <div class="footer-contacts">
        <p>For enquiries:</p>
        <a class="footer-tel" href="tel:+916380609749">+91 63806 09749 (Praveen)</a>
      </div>
      <a href={MAPS} target="_blank" rel="noopener noreferrer" class="footer-map">📍 View Venue on Map</a>
      <p class="footer-copy">Made with love · Praveen &amp; Karthika · 2026</p>
    </div>
  </footer>

</WeddingLayout>

<!-- ════════════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════════════ -->
<style is:global>

/* ─── HERO ────────────────────────────────────────────── */
.hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  position: relative;
  overflow: hidden;
  background: var(--dark);
}
.hero-text {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 5rem 4vw 5rem 7vw;
  gap: 1.3rem;
  position: relative;
  z-index: 2;
}
.hero-logo { width: 62px; opacity: 0.88; }
.hero-tagline {
  font-family: var(--fh);
  font-style: italic;
  font-size: 0.88rem;
  color: var(--text-muted);
  letter-spacing: 0.06em;
}
.hero-names { display: flex; flex-direction: column; gap: 0.05rem; }
.hname {
  font-family: var(--fs);
  font-size: clamp(2.8rem, 4.6vw, 4.4rem);
  color: var(--text-light);
  line-height: 1;
  -webkit-text-stroke: 0.5px rgba(201,162,85,0.25);
}
.weds-row {
  display: flex; align-items: center; gap: 0.65rem;
  font-family: var(--fh); font-style: italic;
  font-size: 0.95rem; color: var(--gold);
  margin: 0.3rem 0 0.35rem;
}
.weds-line { flex: 1; max-width: 36px; height: 1px; background: rgba(201,162,85,0.45); }
.hero-meta { display: flex; flex-direction: column; gap: 0.3rem; }
.hero-divi { width: 96px; opacity: 0.45; }
.hero-date { font-family: var(--fh); font-size: 1.05rem; font-weight: 600; color: var(--gold); letter-spacing: 0.04em; }
.hero-venue { font-size: 0.8rem; color: var(--text-muted); letter-spacing: 0.04em; }

/* Countdown */
.countdown { display: flex; align-items: center; gap: 0.45rem; }
.cu {
  display: flex; flex-direction: column; align-items: center;
  background: var(--gold-dim);
  border: 1px solid rgba(201,162,85,0.22);
  padding: 0.6rem 0.85rem;
  min-width: 54px;
}
.cn { font-family: var(--fh); font-size: 1.55rem; font-weight: 700; color: var(--gold); line-height: 1; }
.cl { font-size: 0.58rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-muted); margin-top: 0.18rem; }
.cs { font-size: 1.3rem; color: var(--gold); opacity: 0.45; line-height: 1; margin-bottom: 0.9rem; }

/* CTA buttons */
.hero-cta { display: flex; gap: 0.9rem; flex-wrap: wrap; }
.btn-gold {
  display: inline-block;
  padding: 0.72rem 1.8rem;
  background: var(--gold); color: var(--dark);
  font-family: var(--fb); font-weight: 700;
  font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
  text-decoration: none;
  transition: background 0.2s, transform 0.15s;
}
.btn-gold:hover { background: #dbb96a; transform: translateY(-1px); }
.btn-outline {
  display: inline-block;
  padding: 0.72rem 1.5rem;
  border: 1.5px solid rgba(240,223,200,0.28);
  color: var(--text-light); font-size: 0.8rem; letter-spacing: 0.07em;
  text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
}
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }

/* Quick-access row */
.hero-quick { display: flex; gap: 0.55rem; flex-wrap: wrap; margin-top: -0.2rem; }
.hq-item {
  display: flex; align-items: center; gap: 0.38rem;
  padding: 0.4rem 0.8rem;
  border: 1px solid rgba(201,162,85,0.2);
  text-decoration: none; color: var(--text-muted);
  font-size: 0.7rem; letter-spacing: 0.06em; font-weight: 600;
  transition: border-color 0.2s, color 0.2s;
}
.hq-item:hover { border-color: var(--gold); color: var(--gold); }

/* Hero art panel */
.hero-art {
  position: relative;
  display: flex; align-items: flex-end; justify-content: center;
  overflow: hidden;
}
/* Left edge fade — blends cutout into text panel */
.hero-art::before {
  content: '';
  position: absolute; left: 0; top: 0; bottom: 0; width: 38%;
  background: linear-gradient(to right, var(--dark) 10%, transparent);
  z-index: 1;
}
/* Bottom edge fade */
.hero-art::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 120px;
  background: linear-gradient(to bottom, transparent, var(--dark));
  z-index: 1;
}
.hero-art img {
  height: 92vh; max-height: 740px; width: auto;
  object-fit: contain; object-position: center bottom;
  /* slight warm tint to match the dark/gold palette */
  filter: brightness(0.96) contrast(1.04) saturate(0.9);
  position: relative; z-index: 0;
}
.scroll-hint {
  position: absolute; bottom: 1.75rem; left: 50%;
  transform: translateX(-50%);
  color: var(--gold); font-size: 1.4rem; text-decoration: none;
  animation: bounce 2s ease-in-out infinite; z-index: 5;
}
@keyframes bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50%       { transform: translateX(-50%) translateY(7px); }
}

@media (max-width: 768px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-text { padding: 5.5rem 1.5rem 2.5rem; order: 1; gap: 1.1rem; }
  .hero-art { order: 2; height: 72vw; min-height: 280px; max-height: 480px; }
  .hero-art::before { display: none; }
  .hero-art img { width: auto; height: 100%; object-fit: contain; object-position: center bottom; }
  .hname { font-size: clamp(2.6rem, 12vw, 3.6rem); }
  .countdown { gap: 0.28rem; }
  .cu { min-width: 46px; padding: 0.5rem 0.6rem; }
  .cn { font-size: 1.25rem; }
  .hero-quick { gap: 0.4rem; }
  .hq-item { font-size: 0.65rem; padding: 0.35rem 0.65rem; }
}

/* ─── EVENTS ──────────────────────────────────────────── */
.events-sec { background: var(--cream); color: var(--ink); padding: 5.5rem 1.5rem; text-align: center; }
.sec-wrap { max-width: 900px; margin: 0 auto; }
.ev-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 0.5rem; }
@media (max-width: 640px) { .ev-grid { grid-template-columns: 1fr; } }

.ev-card {
  background: #fff; padding: 2.5rem 1.75rem; text-align: center;
  box-shadow: 0 6px 32px rgba(74,37,53,0.08);
  border-top: 3px solid var(--gold);
  display: flex; flex-direction: column; gap: 0.4rem;
}
.ev-icon { height: 54px; width: auto; margin: 0 auto 0.75rem; opacity: 0.82; }
.ev-title { font-family: var(--fs); font-size: 2rem; color: var(--ink); line-height: 1.05; margin-bottom: 0.3rem; }
.ev-date { font-family: var(--fb); font-weight: 600; font-size: 0.92rem; color: var(--ink); }
.ev-time { font-size: 0.82rem; color: rgba(74,37,53,0.6); }

.ev-venue {
  margin: 0.85rem 0;
  padding: 0.75rem;
  background: var(--cream);
  border-left: 2px solid rgba(201,162,85,0.35);
