---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Praveen Raj</title>
  </head>
  <body style="font-family: sans-serif; text-align: center; padding: 4rem 1rem; background: #f9f1e3; color: #4a2535; min-height: 100vh; margin: 0; box-sizing: border-box;">
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; font-weight: 700;">Praveen Raj</h1>
    <p style="margin-bottom: 2.5rem; color: #7a5565; font-size: 1.05rem;">Software Engineer</p>
    <a
      href="/wedding"
      style="display: inline-block; padding: 0.6rem 1.6rem; border: 1.5px solid #4a2535; color: #4a2535; text-decoration: none; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.15s, color 0.15s;"
      onmouseover="this.style.background='#4a2535';this.style.color='#f9f1e3';"
      onmouseout="this.style.background='transparent';this.style.color='#4a2535';"
    >
      Wedding Invitation
    </a>
  </body>
</html>
