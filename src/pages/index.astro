<!-- ════════════════════════════════════════════════════════
     SCRIPTS
════════════════════════════════════════════════════════ -->
<script>
  // ── Countdown ──────────────────────────────────────────
  const target = new Date('2026-09-13T07:00:00+05:30');

  function tick() {
    const diff = target.getTime() - Date.now();
    if (diff <= 0) {
      const el = document.getElementById('countdown');
      if (el) el.innerHTML = '<p style="font-family:var(--fs);font-size:2rem;color:var(--gold)">It\'s the Big Day! 🎉</p>';
      return;
    }
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const pad = (n: number) => String(n).padStart(2, '0');
    (document.getElementById('cd-d') as HTMLElement).textContent = String(d);
    (document.getElementById('cd-h') as HTMLElement).textContent = pad(h);
    (document.getElementById('cd-m') as HTMLElement).textContent = pad(m);
    (document.getElementById('cd-s') as HTMLElement).textContent = pad(s);
  }
  tick();
  setInterval(tick, 1000);

  // ── Scroll reveal ──────────────────────────────────────
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // ── Floating RSVP FAB ──────────────────────────────────
  const fab  = document.getElementById('rsvp-fab') as HTMLElement;
  const hero = document.getElementById('hero') as HTMLElement;
  function syncFab() {
    fab.classList.toggle('show', window.scrollY > hero.offsetHeight * 0.55);
  }
  window.addEventListener('scroll', syncFab, { passive: true });
  syncFab();
</script>
