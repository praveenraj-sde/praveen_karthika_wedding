.upload-btn {
  display: inline-block; padding: 1.05rem 2.75rem;
  background: var(--gold); color: var(--dark);
  font-family: var(--fb); font-weight: 700;
  font-size: 0.95rem; letter-spacing: 0.08em; text-transform: uppercase;
